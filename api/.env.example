PORT=3001

# =============================================================================
# Ollama (recommended — free on your own hardware / personal server / AWS VM)
# =============================================================================
# With NO OPENAI_API_KEY and NO OPENAI_BASE_URL, the API defaults to:
#   http://127.0.0.1:11434/v1  +  model llama3.2  (or OLLAMA_MODEL below)
#
# Personal server (API runs on same box as Ollama — default above works).
# Remote Ollama (API runs elsewhere):
#   OPENAI_BASE_URL=http://YOUR_SERVER_LAN_IP:11434/v1
# AWS EC2: open port 11434 in the security group (or use a VPN / SSH tunnel instead).
#
# OPENAI_API_KEY=            # leave empty for Ollama
# OPENAI_MODEL=llama3.2      # optional; must match a name `ollama list` knows
OLLAMA_MODEL=llama3.2

# Docker: from repo root run `docker compose up -d ollama`, then pull a model:
#   docker compose exec ollama ollama pull llama3.2

# =============================================================================
# OpenAI / Azure (optional — set OPENAI_API_KEY)
# =============================================================================
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_PRESET=fast
# OPENAI_MODEL=

# Shorter answers (optional)
# OPENAI_MAX_OUTPUT_TOKENS=900

# Tutor follows “guide, don’t solve” instructions better when not too random (0–2, default 0.55)
# OPENAI_TEMPERATURE=0.5

# --- Lab snapshot (optional) ---
# LAB_CODE_MAX_CHARS=12000
# LAB_COMPACT_BLANK_LINES=0
# LAB_STRIP_TRAILING_WS=0

# =============================================================================
# Course-material grounding (read-only csuf-ssp-oer connection)
# =============================================================================
# The tutor indexes the csuf-ssp-oer materials at startup and grounds answers
# in the most relevant passages (no external search service or embeddings).
#
# By default it looks for csuf-ssp-oer as a SIBLING of this repo, i.e.
#   ../../csuf-ssp-oer  (faller-ai-tutor/csuf-ssp-oer)
# Point it elsewhere with an absolute or relative path:
# OER_CONTENT_PATH=../../csuf-ssp-oer
#
# How many passages to retrieve per question, and the max characters of OER
# text injected into the prompt:
# OER_TOP_K=4
# OER_CONTEXT_MAX_CHARS=5000
#
# Answer-key / solution files are excluded by default (keeps "guide, don't
# solve" intact). Set to 1 ONLY for an instructor build:
# OER_INCLUDE_KEYS=0

# Verify the read-only OER connection without starting the server:
#   npm run index:oer -w api

# SERVE_WEB=1
