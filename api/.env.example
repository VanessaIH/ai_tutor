PORT=3001

# OpenRouter — key from https://openrouter.ai/keys (starts with sk-or-)
# Add $10+ credits for 1,000/day on :free models, or use paid model id below.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=YOUR_OPENROUTER_KEY
OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct
# Paid (no daily free cap, uses credits): meta-llama/llama-3.3-70b-instruct
OPENAI_MAX_OUTPUT_TOKENS=600
OPENAI_TEMPERATURE=0.3

# Optional OpenRouter attribution (recommended on Vercel)
# OPENROUTER_HTTP_REFERER=https://ai-tutor-ssp-web.vercel.app
# OPENROUTER_APP_NAME=CSUF SSP Lab Tutor

OER_TOP_K=4
OER_CONTEXT_MAX_CHARS=2600

# LLM rate-limit queue (shared key on Vercel / class site)
# LLM_MAX_CONCURRENT=2
# LLM_MIN_INTERVAL_MS=400
# LLM_RETRY_MAX=4
# LLM_RETRY_BASE_MS=1000
# LLM_GATE=0

# S3 reader (tutor-reader IAM) — paste keys from your team lead
AWS_ACCESS_KEY_ID=YOUR_S3_READ_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_S3_READ_SECRET_KEY
