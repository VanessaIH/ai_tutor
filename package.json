{
  "name": "tutor-chat-bot",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan \"npm run dev -w api\" \"npm run dev -w web\"",
    "build": "npm run build -w web",
    "start": "npm run start -w api",
    "ollama:up": "docker compose up -d ollama",
    "ollama:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
